# ════════════════════════════════════════
# InRecord 環境變數設定
# 複製此檔案為 .env.local，填入你的值
# 權威清單見 CLAUDE.md「環境變數」一節
# ════════════════════════════════════════

# ── Supabase ──
# 前往 supabase.com → 你的專案 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://你的專案ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...你的anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...你的service_role_key

# ── Brevo（原 Sendinblue，Email 名單 + 交易信）──
# 前往 app.brevo.com → Settings → API Keys
BREVO_API_KEY=xkeysib-你的API金鑰
BREVO_LIST_ID=3
BREVO_SENDER_EMAIL=hello@你的網域.com
BREVO_SENDER_NAME=InRecord
BREVO_TEMPLATE_ID=

# ── PAYUNi 統一金流 ──
# 測試：https://sandbox-api.payuni.com.tw/api/upp
# 正式：https://api.payuni.com.tw/api/upp（並換成正式商店代號 / HashKey / HashIV）
PAYUNI_MERCHANT_ID=你的商店代號
PAYUNI_HASH_KEY=你的HashKey
PAYUNI_HASH_IV=你的HashIV
PAYUNI_API_URL=https://sandbox-api.payuni.com.tw/api/upp

# ── 光貿 Amego 電子發票 ──
# 測試環境：identifier=12345678 / app_key=sHeq7t8G1wiQvhAuIM27
# 正式環境：AMEGO_IDENTIFIER 改為公司統編，AMEGO_APP_KEY 改為光貿客服提供的正式金鑰
AMEGO_API_URL=https://invoice-api.amego.tw
AMEGO_IDENTIFIER=12345678
AMEGO_APP_KEY=sHeq7t8G1wiQvhAuIM27

# ── Bunny Stream（影片播放）──
# 教室影片以 iframe.mediadelivery.net 嵌入，需 Library ID
NEXT_PUBLIC_BUNNY_LIBRARY_ID=你的BunnyLibraryID

# ── 網站設定 ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── 安全性 ──
# JWT_SECRET：簽發後台 / 教室 token；CRON_SECRET：保護排程路由
# 正式上線請改成高強度隨機字串
JWT_SECRET=請改成隨機長字串
CRON_SECRET=請改成隨機長字串

# ── 後台登入 ──
# 正式上線請換成安全的密碼
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=ChangeMe123!
