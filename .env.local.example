# ════════════════════════════════════════
# InRecord 環境變數設定
# 複製此檔案為 .env.local，填入你的值
# ════════════════════════════════════════

# ── Supabase ──
# 前往 supabase.com → 你的專案 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://你的專案ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...你的anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...你的service_role_key

# ── Brevo（原 Sendinblue）──
# 前往 app.brevo.com → Settings → API Keys
BREVO_API_KEY=xkeysib-你的API金鑰
BREVO_LIST_ID=3
BREVO_SENDER_EMAIL=hello@你的網域.com
BREVO_SENDER_NAME=InRecord
BREVO_TEMPLATE_ID=

# ── Stripe ──
# 前往 dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_你的測試金鑰
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_你的公開金鑰

# Stripe Price IDs（Products → 對應方案的 price_xxx）
STRIPE_PRICE_ID_FAN1=price_xxx    # 粉絲限定【1】$2,200
STRIPE_PRICE_ID_FAN2=price_xxx    # 粉絲限定【2】$2,400
STRIPE_PRICE_ID_EARLY1=price_xxx  # 第一波早鳥【1】$2,800
STRIPE_PRICE_ID_EARLY2=price_xxx  # 第二波早鳥【2】$3,100
STRIPE_PRICE_ID_EARLY3=price_xxx  # 最後早鳥【3】$3,300
STRIPE_PRICE_ID_FULL=price_xxx    # 原價 $3,500

# ── 光貿 Amego 電子發票 ──
# 測試環境：invoice=12345678 / app_key=sHeq7t8G1wiQvhAuIM27
# 正式環境：AMEGO_IDENTIFIER 改為碩樂公司統編，AMEGO_APP_KEY 改為光貿客服提供的正式金鑰
AMEGO_API_URL=https://invoice-api.amego.tw
AMEGO_IDENTIFIER=12345678
AMEGO_APP_KEY=sHeq7t8G1wiQvhAuIM27

# ── 網站設定 ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── 後台登入 ──
# 正式上線請換成安全的密碼
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=ChangeMe123!
